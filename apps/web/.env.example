# =============================================================================
# Next.js front-end - environment variables
# Copy this file to apps/web/.env.local and fill in the values.
#
# Loaded automatically by `next dev` from this directory.
# =============================================================================

# ---- Inter-service URL ------------------------------------------------------
# How the Next.js app reaches the Mastra service. Keep in sync with the
# Mastra service's MASTRA_PORT in apps/mastra/.env.
MASTRA_URL=http://localhost:4111

# ---- Next.js dev port (optional) --------------------------------------------
# Port the Next.js dev server binds to. Defaults to 3000.
WEB_PORT=3000
