# =============================================================================
# Mastra service - environment variables
# Copy this file to apps/mastra/.env and fill in the values.
#
# Loaded automatically by `mastra dev` from this directory.
# =============================================================================

# ---- Scraping (Firecrawl) ---------------------------------------------------
# Get a free key at https://firecrawl.dev (sign up, project, API keys).
FIRECRAWL_API_KEY=

# ---- LLM (NVIDIA NIM by default; OpenAI-compatible) -------------------------
# Default: NVIDIA NIM. Get a free key at https://build.nvidia.com.
# To swap to OpenAI: set LLM_BASE_URL=https://api.openai.com/v1, set
# LLM_API_KEY to your OpenAI key, and pick a tool-calling-capable LLM_MODEL
# (e.g. gpt-4o-mini). For Anthropic, use Mastra's native provider routing -
# see apps/mastra/src/model/nim.ts for details.
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=
# Pick a model from build.nvidia.com that supports tool calling and JSON mode.
# Suggestions: meta/llama-3.3-70b-instruct, nvidia/llama-3.1-nemotron-70b-instruct.
LLM_MODEL=meta/llama-3.3-70b-instruct

# ---- Server port ------------------------------------------------------------
# Port the Mastra dev server binds to. The Next.js app proxies here.
MASTRA_PORT=4111
